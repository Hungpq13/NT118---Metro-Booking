<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="40dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView8"
            android:layout_width="39dp"
            android:layout_height="35sp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/arrow" />

        <TextView
            android:layout_width="338dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="30sp"
            android:text="Trạm xung quanh"
            android:textAlignment="center"
            android:textSize="30sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="370dp"
        android:layout_height="91dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginVertical="20sp"
        android:background="@drawable/banner_radius"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15sp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView_TXQ_1"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20sp"
                android:text="Trạm 1"
                android:textDirection="firstStrong"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/TXQ_tinhtrang1"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="50sp"
                android:background="@color/blue_light"
                android:text="Gần đến"
                android:textAlignment="center"
                android:textColor="#0478AE"
                android:textColorLink="#B3DFF3"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20sp"
            android:layout_marginTop="20sp"
            android:orientation="horizontal">


            <ImageView
                android:id="@+id/imageview_clock1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="0sp"
                android:layout_weight="1"
                app:srcCompat="@drawable/clock" />

            <TextView
                android:id="@+id/TXQ_Time1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="80sp"
                android:text="Thời gian đến: Hôm nay / 8:35"
                android:textSize="17sp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="370dp"
        android:layout_height="91dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginVertical="20sp"
        android:background="@drawable/banner_radius"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15sp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView_TXQ_2"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20sp"
                android:text="Trạm 2"
                android:textDirection="firstStrong"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/TXQ_tinhtrang2"
                android:layout_width="95dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="50dp"
                android:background="#99FF99"
                android:text="Di chuyển"
                android:textAlignment="center"
                android:textColor="#009900"
                android:textColorLink="#B3DFF3"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20sp"
            android:layout_marginTop="20sp"
            android:orientation="horizontal">


            <ImageView
                android:id="@+id/imageview_clock2"
                android:layout_width="100sp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:srcCompat="@drawable/clock" />

            <TextView
                android:id="@+id/TXQ_Time2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="80sp"
                android:text="Thời gian đến: Hôm nay / 8:45"
                android:textSize="17sp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="370dp"
        android:layout_height="91dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginVertical="20sp"
        android:background="@drawable/banner_radius"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15sp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView_TXQ_3"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20sp"
                android:text="Trạm 5"
                android:textDirection="firstStrong"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/TXQ_tinhtrang3"
                android:layout_width="95dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="40sp"
                android:background="#99FF99"
                android:text="Di chuyển"
                android:textAlignment="center"
                android:textColor="#009900"
                android:textColorLink="#B3DFF3"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20sp"
            android:layout_marginTop="20sp"
            android:orientation="horizontal">


            <ImageView
                android:id="@+id/imageview_clock3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:srcCompat="@drawable/clock" />

            <TextView
                android:id="@+id/TXQ_Time3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="80sp"
                android:text="Thời gian đến: Hôm nay / 8:55"
                android:textSize="17sp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="91dp"
        android:layout_marginHorizontal="20sp"
        android:layout_marginVertical="20sp"
        android:background="@drawable/banner_radius"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15sp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView_TXQ_4"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20sp"
                android:text="Trạm 1"
                android:textDirection="firstStrong"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/TXQ_tinhtrang4"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="40sp"
                android:background="#FFFFCC"
                android:text="Gần đến"
                android:textAlignment="center"
                android:textColor="#FF9933"
                android:textColorLink="#0478AE"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20sp"
            android:layout_marginTop="20sp"
            android:orientation="horizontal">


            <ImageView
                android:id="@+id/imageview_clock4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:srcCompat="@drawable/clock" />

            <TextView
                android:id="@+id/TXQ_Time4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="80sp"
                android:text="Thời gian đến: Hôm nay / 9:20"
                android:textSize="17sp" />
        </LinearLayout>

    </LinearLayout>


</LinearLayout>